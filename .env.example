# Spotify — full-track playback via the Web Playback SDK (Premium listeners only).
# This one is PUBLIC (client-side PKCE), so it must be the NEXT_PUBLIC_ variant.
# Same value as your app's Client ID from https://developer.spotify.com/dashboard.
# Without it, the player falls back to the 30-second embed preview.
NEXT_PUBLIC_SPOTIFY_CLIENT_ID=

# Contact form (Resend)
RESEND_API_KEY=

# Note: the track list is pulled from Spotify's public embed by
# `bun scripts/fetch-tracks.ts` and committed to src/lib/spotify/tracks.json.
# No server-side Spotify secret is needed anymore.
